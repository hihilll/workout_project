/* 顶部导航 */
.profile-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #111;
}

.header-action {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon {
  font-size: 28rpx;
}

/* 个人资料卡片 */
.profile-card {
  position: relative;
  background: #111;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
}

.bg-circle.c1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.bg-circle.c2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -50rpx;
  left: -30rpx;
}

.card-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 32rpx;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 36rpx;
}

.avatar-wrapper {
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #333, #555);
  border: 4rpx solid rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-inner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
}

.vip-badge {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, var(--volt-deep), var(--volt));
  border-radius: 20rpx;
  border: 3rpx solid #111;
}

.vip-badge text {
  font-size: 18rpx;
  font-weight: 900;
  color: #111;
}

.user-detail {
  flex: 1;
}

.username {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.name {
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
}

.level-tag {
  padding: 6rpx 16rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  font-size: 20rpx;
  color: rgba(255,255,255,0.8);
  font-weight: 600;
}

.goal-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.goal-icon {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--volt);
  flex-shrink: 0;
}

.goal-info text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

/* 身体数据 */
.body-metrics {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.08);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
}

.metric-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.metric-item.highlight {
  position: relative;
}

.metric-item.highlight::before {
  content: "";
  position: absolute;
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--volt);
  border-radius: 2rpx;
}

.metric-value {
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}

.metric-unit {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 600;
}

.metric-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}

.metric-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.15);
}

/* 进度条 */
.weight-progress {
  background: rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 20rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-info text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.progress-value {
  font-weight: 800;
  color: #fff !important;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--volt-deep), var(--volt));
  border-radius: 6rpx;
  transition: width 0.6s ease;
}

/* 空状态 */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 28rpx;
  border: 2rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.empty-icon {
  margin-bottom: 32rpx;
}

.empty-user {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.empty-user-head {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ddd;
}

.empty-user-body {
  width: 60rpx;
  height: 30rpx;
  border-radius: 30rpx 30rpx 0 0;
  background: #ddd;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #111;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #777;
  margin-bottom: 40rpx;
}

/* 数据统计卡片 */
.stats-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  border: 2rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.stats-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stats-action text {
  font-size: 24rpx;
  color: #777;
}

.action-arrow {
  font-size: 28rpx;
  color: #bbb;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
}

.stat-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.stat-icon.streak,
.stat-icon.workout,
.stat-icon.calories,
.stat-icon.days {
  background: var(--volt-soft);
  color: #3d4d0a;
  font-size: 24rpx;
  font-weight: 800;
}

.stat-content {
  flex: 1;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 900;
  color: #111;
  line-height: 1;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #777;
}

/* 功能菜单 */
.menu-section {
  margin-bottom: 24rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.menu-grid {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid #f0f0f0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f8f8;
}

.menu-item.simple {
  padding: 24rpx;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.menu-icon.personal,
.menu-icon.goal,
.menu-icon.history,
.menu-icon.favorite,
.menu-icon.food,
.menu-icon.diet {
  background: var(--volt-soft);
  color: #3d4d0a;
  font-size: 26rpx;
  font-weight: 800;
}

.menu-icon-small {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.menu-info {
  flex: 1;
  min-width: 0;
}

.menu-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #777;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #111;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
}

/* 系统设置 */
.menu-list {
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid #f0f0f0;
  overflow: hidden;
}

/* 版本信息 */
.version-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 40rpx 0;
}

.version-info text {
  font-size: 22rpx;
  color: #bbb;
}

/* 响应式调整 */
@media (max-width: 600rpx) {
  .user-info {
    flex-direction: column;
    text-align: center;
  }
  
  .username {
    justify-content: center;
  }
  
  .goal-info {
    justify-content: center;
  }
  
  .stats-grid {
    grid-template-columns: 1fr;
  }
}
