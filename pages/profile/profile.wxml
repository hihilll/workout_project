<view class="page safe-bottom">
  <!-- 顶部导航 -->
  <view class="profile-header">
    <view class="header-title">我的</view>
    <view class="header-action" bindtap="openSettings">
      <view class="settings-icon">⚙</view>
    </view>
  </view>

  <!-- 个人资料卡片 -->
  <view class="profile-card" wx:if="{{profile}}">
    <!-- 背景装饰 -->
    <view class="card-bg">
      <view class="bg-circle c1"></view>
      <view class="bg-circle c2"></view>
    </view>
    
    <view class="card-content">
      <!-- 头像和基本信息 -->
      <view class="user-info">
        <view class="avatar-wrapper">
          <view class="avatar">
            <view class="avatar-inner">
              <text class="avatar-text">{{profile.gender === 'male' ? '男' : '女'}}</text>
            </view>
          </view>
          <view class="vip-badge" wx:if="{{streak >= 7}}">
            <text>PRO</text>
          </view>
        </view>
        
        <view class="user-detail">
          <view class="username">
            <text class="name">{{profile.gender === 'male' ? '健身达人' : '元气少女'}}</text>
            <view class="level-tag">{{levelLabel}}</view>
          </view>
          <view class="goal-info">
            <view class="goal-icon"></view>
            <text>{{goalLabel}} · {{locationLabel}}</text>
          </view>
        </view>
      </view>
      
      <!-- 身体数据 -->
      <view class="body-metrics">
        <view class="metric-item">
          <view class="metric-value">{{profile.height}}</view>
          <view class="metric-unit">cm</view>
          <view class="metric-label">身高</view>
        </view>
        <view class="metric-divider"></view>
        <view class="metric-item highlight">
          <view class="metric-value">{{profile.weight}}</view>
          <view class="metric-unit">kg</view>
          <view class="metric-label">当前体重</view>
        </view>
        <view class="metric-divider"></view>
        <view class="metric-item">
          <view class="metric-value">{{profile.targetWeight}}</view>
          <view class="metric-unit">kg</view>
          <view class="metric-label">目标体重</view>
        </view>
      </view>
      
      <!-- 进度条 -->
      <view class="weight-progress">
        <view class="progress-info">
          <text>距离目标</text>
          <text class="progress-value">{{weightDiff}}kg</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-card" wx:else>
    <view class="empty-icon">
      <view class="empty-user">
        <view class="empty-user-head"></view>
        <view class="empty-user-body"></view>
      </view>
    </view>
    <view class="empty-title">还没有个人资料</view>
    <view class="empty-desc">填写资料后会自动生成训练和饮食计划</view>
    <button class="primary-btn" bindtap="goOnboarding">
      <text>开始填写</text>
      <text class="btn-arrow">→</text>
    </button>
  </view>

  <!-- 数据统计卡片 -->
  <view class="stats-card" wx:if="{{profile}}">
    <view class="stats-header">
      <view class="stats-title">我的数据</view>
      <view class="stats-action" bindtap="goStats">
        <text>查看详情</text>
        <text class="action-arrow">›</text>
      </view>
    </view>
    
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-icon streak">
          <text>连</text>
        </view>
        <view class="stat-content">
          <view class="stat-value">{{streak}}</view>
          <view class="stat-label">连续打卡</view>
        </view>
      </view>
      
      <view class="stat-item">
        <view class="stat-icon workout">
          <text>练</text>
        </view>
        <view class="stat-content">
          <view class="stat-value">{{workoutCount}}</view>
          <view class="stat-label">训练次数</view>
        </view>
      </view>
      
      <view class="stat-item">
        <view class="stat-icon calories">
          <text>燃</text>
        </view>
        <view class="stat-content">
          <view class="stat-value">{{totalCalories}}</view>
          <view class="stat-label">消耗热量</view>
        </view>
      </view>
      
      <view class="stat-item">
        <view class="stat-icon days">
          <text>日</text>
        </view>
        <view class="stat-content">
          <view class="stat-value">{{activeDays}}</view>
          <view class="stat-label">活跃天数</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="section-header">
      <view class="section-title">我的功能</view>
    </view>
    
    <view class="menu-grid">
      <view class="menu-item" bindtap="goOnboarding">
        <view class="menu-icon personal">
          <text>资</text>
        </view>
        <view class="menu-info">
          <view class="menu-name">个人资料</view>
          <view class="menu-desc">编辑基本信息</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      
      <view class="menu-item" data-action="goal" bindtap="handleMenuTap">
        <view class="menu-icon goal">
          <text>标</text>
        </view>
        <view class="menu-info">
          <view class="menu-name">当前目标</view>
          <view class="menu-desc">{{goalLabel || '未设置'}}</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      
      <view class="menu-item" data-action="history" bindtap="handleMenuTap">
        <view class="menu-icon history">
          <text>录</text>
        </view>
        <view class="menu-info">
          <view class="menu-name">历史计划</view>
          <view class="menu-desc">查看过往记录</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      
      <view class="menu-item" data-action="exercises" bindtap="handleMenuTap">
        <view class="menu-icon favorite">
          <text>★</text>
        </view>
        <view class="menu-info">
          <view class="menu-name">收藏动作</view>
          <view class="menu-desc">常用训练动作</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      
      <view class="menu-item" data-action="foods" bindtap="handleMenuTap">
        <view class="menu-icon food">
          <text>食</text>
        </view>
        <view class="menu-info">
          <view class="menu-name">常吃食物</view>
          <view class="menu-desc">饮食偏好设置</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      
      <view class="menu-item" data-action="diet" bindtap="handleMenuTap">
        <view class="menu-icon diet">
          <text>偏</text>
        </view>
        <view class="menu-info">
          <view class="menu-name">饮食偏好</view>
          <view class="menu-desc">{{dietModeText}}</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 系统设置 -->
  <view class="menu-section">
    <view class="section-header">
      <view class="section-title">系统设置</view>
    </view>
    
    <view class="menu-list">
      <view class="menu-item simple" data-action="settings" bindtap="handleMenuTap">
        <view class="menu-icon-small">
          <text>⚙</text>
        </view>
        <text class="menu-label">设置</text>
        <view class="menu-arrow">›</view>
      </view>
      
      <view class="menu-item simple" data-action="help" bindtap="handleMenuTap">
        <view class="menu-icon-small">
          <text>?</text>
        </view>
        <text class="menu-label">帮助与反馈</text>
        <view class="menu-arrow">›</view>
      </view>
      
      <view class="menu-item simple" bindtap="showAbout">
        <view class="menu-icon-small">
          <text>i</text>
        </view>
        <text class="menu-label">关于</text>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>FitPlan v1.2.0</text>
    <text>本地存储 · 数据安全</text>
  </view>
</view>
