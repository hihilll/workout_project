/* 顶部导航区 */
.app-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
}

.header-left {
  flex: 1;
}

.header-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #111;
  letter-spacing: -1rpx;
}

.header-subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #777;
}

.header-right {
  display: flex;
  gap: 16rpx;
}

.header-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
}

.header-btn-icon {
  font-size: 24rpx;
  font-weight: 800;
}

.header-btn text {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
}

/* 快捷操作栏 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.quick-actions::-webkit-scrollbar {
  display: none;
}

.quick-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 40rpx;
  white-space: nowrap;
  transition: all 0.2s;
}

.quick-pill:active {
  transform: scale(0.96);
  background: #f8f8f8;
}

.quick-pill.active {
  background: #111;
  border-color: #111;
  color: #fff;
}

.pill-icon {
  font-size: 24rpx;
}

.quick-pill text {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.quick-pill.active text {
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  margin-bottom: 40rpx;
}

.empty-plate {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.06);
}

.empty-plate-inner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff, #f0f0f0);
  border: 4rpx solid #ddd;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #111;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #777;
  line-height: 1.6;
  margin-bottom: 48rpx;
  max-width: 500rpx;
}

/* 热量概览卡片 */
.calorie-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.04);
  border: 2rpx solid #f0f0f0;
}

.calorie-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 36rpx;
}

/* 环形进度 */
.calorie-ring-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.calorie-ring {
  width: 240rpx;
  height: 240rpx;
  position: relative;
}

.ring-progress {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-inner {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.ring-number {
  font-size: 52rpx;
  font-weight: 900;
  color: #111;
  line-height: 1;
}

.ring-unit {
  font-size: 22rpx;
  color: #777;
  margin-top: 6rpx;
}

.calorie-status {
  font-size: 24rpx;
  font-weight: 700;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.calorie-status.good {
  background: #e8f5e9;
  color: #2e7d32;
}

.calorie-status.low {
  background: #fff3e0;
  color: #ef6c00;
}

.calorie-status.over {
  background: #fbe9e7;
  color: #c62828;
}

/* 营养素进度 */
.macro-progress-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.macro-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.macro-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.macro-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.macro-dot.protein {
  background: #111111;
}

.macro-dot.carbs {
  background: var(--volt-deep);
}

.macro-dot.fat {
  background: #b8c98e;
}

.macro-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
}

.macro-value {
  font-size: 24rpx;
  color: #777;
  font-weight: 600;
}

.macro-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.macro-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.6s ease;
  min-width: 4%;
}

.macro-fill.protein {
  background: linear-gradient(90deg, #2a2a2a, #111111);
}

.macro-fill.carbs {
  background: linear-gradient(90deg, var(--volt-deep), var(--volt));
}

.macro-fill.fat {
  background: linear-gradient(90deg, #c4d49e, #b8c98e);
}

/* 营养提示 */
.nutrition-tips {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  border: 2rpx solid #f0f0f0;
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tips-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: var(--volt-soft);
  color: #3d4d0a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.tips-header text {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #777;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.tip-item.ok .tip-dot {
  background: #4caf50;
}

.tip-item.low .tip-dot {
  background: #ff9800;
}

.tip-item.high .tip-dot {
  background: #f44336;
}

.tip-text {
  font-size: 24rpx;
  color: #555;
  line-height: 1.5;
}

/* 餐次列表区域 */
.meals-section {
  margin-top: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111;
}

.section-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.section-action text {
  font-size: 24rpx;
  color: #555;
  font-weight: 600;
}

.action-arrow {
  font-size: 28rpx;
  font-weight: 800;
}

.section-count {
  font-size: 24rpx;
  color: #777;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 餐次列表 */
.meal-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 餐次卡片 */
.meal-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
  border: 2rpx solid #f0f0f0;
}

.meal-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.meal-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.meal-icon-wrapper.breakfast {
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
}

.meal-icon-wrapper.lunch {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
}

.meal-icon-wrapper.dinner {
  background: linear-gradient(135deg, #e3f2fd, #bbdefb);
}

.meal-icon-wrapper.snack {
  background: linear-gradient(135deg, #fce4ec, #f8bbd0);
}

.meal-icon-text {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.meal-info {
  flex: 1;
  min-width: 0;
}

.meal-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #111;
}

.meal-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 6rpx;
}

.meal-cal {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
}

.meal-divider {
  color: #ddd;
  font-size: 20rpx;
}

.meal-suggest {
  font-size: 22rpx;
  color: #999;
}

.meal-actions-btn {
  display: flex;
  gap: 12rpx;
}

.meal-action {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.meal-action text {
  font-size: 28rpx;
  color: #777;
  font-weight: 600;
}

/* 食物列表 */
.food-list {
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.food-item {
  background: #f8f8f8;
  border-radius: 20rpx;
  padding: 20rpx;
}

.food-info {
  margin-bottom: 16rpx;
}

.food-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 8rpx;
}

.food-macro {
  display: flex;
  gap: 20rpx;
}

.food-macro text {
  font-size: 22rpx;
  color: #777;
  font-weight: 600;
}

/* 份量控制 */
.food-amount {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.amount-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.amount-btn:active {
  transform: scale(0.92);
  background: #f0f0f0;
}

.amount-btn text {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.amount-value {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  min-width: 100rpx;
  justify-content: center;
}

.amount-value input {
  width: 80rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.amount-unit {
  font-size: 22rpx;
  color: #777;
  font-weight: 600;
}

/* 食物操作 */
.food-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.food-action-btn {
  padding: 10rpx 24rpx;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 30rpx;
}

.food-action-btn text {
  font-size: 22rpx;
  color: #555;
  font-weight: 600;
}

.food-action-btn.delete {
  border-color: #ffcdd2;
  background: #fff5f5;
}

.food-action-btn.delete text {
  color: #c62828;
}

/* 餐次底部 */
.meal-footer {
  display: flex;
  border-top: 2rpx solid #f0f0f0;
}

.meal-footer-btn {
  flex: 1;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}

.meal-footer-btn:first-child {
  border-right: 2rpx solid #f0f0f0;
}

.meal-footer-btn:active {
  background: #f8f8f8;
}

.meal-footer-btn text {
  font-size: 24rpx;
  color: #555;
  font-weight: 600;
}

/* 添加餐次卡片 */
.add-meal-card {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
  background: #f8f8f8;
  border-radius: 24rpx;
  border: 3rpx dashed #ddd;
  margin-top: 24rpx;
  transition: all 0.2s;
}

.add-meal-card:active {
  background: #f0f0f0;
  border-color: #bbb;
}

.add-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #555;
}

.add-meal-card text {
  font-size: 28rpx;
  color: #555;
  font-weight: 600;
}

/* 常用餐区域 */
.saved-meals-section {
  margin-top: 8rpx;
}

.saved-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
  margin-left: -40rpx;
  margin-right: -40rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
}

.saved-list {
  display: inline-flex;
  gap: 20rpx;
}

.saved-card {
  width: 300rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  border: 2rpx solid #f0f0f0;
  white-space: normal;
}

.saved-header {
  margin-bottom: 16rpx;
}

.saved-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #111;
  margin-bottom: 8rpx;
}

.saved-cal {
  font-size: 24rpx;
  font-weight: 700;
  color: #555;
}

.saved-summary {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  height: 66rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  margin-bottom: 20rpx;
}

.saved-actions {
  display: flex;
  gap: 12rpx;
}

.saved-btn {
  flex: 1;
  padding: 14rpx;
  background: #111;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.saved-btn text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
}

.saved-btn.delete {
  background: #f5f5f5;
  border: 2rpx solid #eee;
}

.saved-btn.delete text {
  color: #777;
}

/* 周计划入口卡片 */
.week-plan-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  border: 2rpx solid #f0f0f0;
  margin-top: 8rpx;
}

.week-plan-card:active {
  background: #f8f8f8;
}

.week-plan-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.week-plan-icon {
  width: 56rpx;
  height: 56rpx;
  background: var(--volt-soft);
  color: #3d4d0a;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.week-plan-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.week-plan-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111;
}

.week-plan-meta {
  font-size: 24rpx;
  color: #777;
}

.week-plan-arrow {
  font-size: 40rpx;
  color: #bbb;
  font-weight: 300;
}

/* 底部操作区 */
.bottom-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.secondary-btn {
  flex: 1;
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.secondary-btn::after {
  display: none;
}

.secondary-btn text {
  font-size: 28rpx;
  font-weight: 700;
  color: #555;
}

.primary-btn {
  flex: 1.5;
  height: 96rpx;
  background: #111;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.primary-btn::after {
  display: none;
}

.primary-btn text {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.btn-arrow {
  margin-left: 12rpx;
  font-size: 32rpx;
}

/* 响应式调整 */
@media (max-width: 600rpx) {
  .calorie-content {
    gap: 28rpx;
  }
  
  .calorie-ring {
    width: 200rpx;
    height: 200rpx;
  }
  
  .ring-inner {
    width: 150rpx;
    height: 150rpx;
  }
  
  .ring-number {
    font-size: 44rpx;
  }
}
