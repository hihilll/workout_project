<view class="page safe-bottom workout-page">
  <block wx:if="{{day}}">
    <!-- 头部区域 -->
    <view class="workout-header">
      <view class="header-left">
        <button class="back-btn" bindtap="goBack">‹</button>
        <view class="header-info">
          <view class="header-day">{{day.dayName}}</view>
          <view class="header-title">{{day.title}}</view>
        </view>
      </view>
      <view class="header-stats">
        <view class="stat-item">
          <text class="stat-num">{{day.exercises.length}}</text>
          <text class="stat-label">动作</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{totalSets}}</text>
          <text class="stat-label">组</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <button class="start-btn" bindtap="startWorkout">
        <view class="play-icon">▶</view>
        <text>开始训练</text>
      </button>
      <button class="add-btn" bindtap="openExercisePicker">
        <text>＋</text>
      </button>
    </view>

    <!-- 训练日设置 -->
    <view class="settings-card section">
      <view class="settings-header">
        <view class="settings-title">训练日设置</view>
        <button class="rest-toggle {{day.isRestDay ? 'active' : ''}}" bindtap="{{day.isRestDay ? 'restoreTrainingDay' : 'setRestDay'}}">
          {{day.isRestDay ? '恢复训练' : '设为休息'}}
        </button>
      </view>
      
      <view class="settings-body">
        <view class="setting-row">
          <text class="setting-label">名称</text>
          <input class="setting-input" value="{{dayDraftTitle}}" bindblur="updateDayTitle" placeholder="输入训练日名称" />
        </view>
        
        <view class="setting-row">
          <text class="setting-label">类型</text>
          <scroll-view scroll-x class="type-scroll" show-scrollbar="{{false}}">
            <view class="type-chips">
              <view wx:for="{{dayTypeOptions}}" wx:key="value" 
                    class="type-chip {{day.trainingType === item.value ? 'active' : ''}}" 
                    data-type="{{item.value}}" 
                    bindtap="replaceDayType">
                {{item.label}}
              </view>
            </view>
          </scroll-view>
        </view>
      </view>
    </view>

    <!-- 警告提示 -->
    <view class="warning-card section" wx:for="{{plan.warnings}}" wx:key="*this">
      <view class="warning-icon">⚠</view>
      <text>{{item}}</text>
    </view>

    <!-- 热身区域 -->
    <view class="phase-section section" wx:if="{{day.warmups.length}}">
      <view class="phase-header">
        <view class="phase-badge warmup">热身</view>
        <view class="phase-count">{{day.warmups.length}} 个动作</view>
      </view>
      <view class="phase-list">
        <view class="phase-item" wx:for="{{day.warmups}}" wx:key="id">
          <view class="item-index">{{index + 1}}</view>
          <view class="item-info">
            <view class="item-name">{{item.exerciseName}}</view>
            <view class="item-meta">{{item.reps}}</view>
          </view>
          <button class="item-delete" data-index="{{index}}" catchtap="removeWarmup">×</button>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state section" wx:if="{{!day.exercises.length}}">
      <view class="empty-icon">
        <view class="icon-bar"></view>
        <view class="icon-bar"></view>
        <view class="icon-bar"></view>
      </view>
      <view class="empty-title">暂无训练动作</view>
      <view class="empty-desc">点击上方「+」按钮从动作库添加</view>
    </view>

    <!-- 正式训练区域 -->
    <view class="exercises-section section" wx:if="{{day.exercises.length}}">
      <view class="section-header">
        <view class="section-title">正式训练</view>
        <view class="section-count">{{day.exercises.length}} 个动作</view>
      </view>
      
      <view class="exercise-list">
        <view class="exercise-item {{dragIndex === index ? 'dragging' : ''}}" wx:for="{{day.exercises}}" wx:key="id">
          <!-- 动作头部 -->
          <view class="item-header">
            <view class="drag-handle" data-index="{{index}}" catchtouchstart="startExerciseDrag" catchtouchmove="moveExerciseDrag" catchtouchend="endExerciseDrag">
              <view class="drag-dot"></view>
              <view class="drag-dot"></view>
            </view>
            <view class="item-title-wrap">
              <view class="item-title">{{item.exerciseName}}</view>
              <view class="item-instruction">{{item.instruction}}</view>
            </view>
            <button class="item-menu" data-index="{{index}}" catchtap="openExerciseMenu">⋯</button>
          </view>
          
          <!-- 参数编辑 -->
          <view class="params-grid">
            <view class="param-item">
              <text class="param-label">组数</text>
              <input class="param-input" type="number" value="{{item.sets}}" data-index="{{index}}" data-field="sets" bindinput="updateExercise" />
            </view>
            <view class="param-item">
              <text class="param-label">次数</text>
              <input class="param-input" value="{{item.reps}}" data-index="{{index}}" data-field="reps" bindinput="updateExercise" />
            </view>
            <view class="param-item">
              <text class="param-label">重量</text>
              <input class="param-input" value="{{item.weight}}" data-index="{{index}}" data-field="weight" bindinput="updateExercise" placeholder="可选" />
            </view>
            <view class="param-item">
              <text class="param-label">休息</text>
              <input class="param-input" type="number" value="{{item.restSeconds}}" data-index="{{index}}" data-field="restSeconds" bindinput="updateExercise" />
              <text class="param-unit">秒</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 拉伸区域 -->
    <view class="phase-section section" wx:if="{{day.stretches.length}}">
      <view class="phase-header">
        <view class="phase-badge stretch">拉伸</view>
        <view class="phase-count">{{day.stretches.length}} 个动作</view>
      </view>
      <view class="phase-list">
        <view class="phase-item" wx:for="{{day.stretches}}" wx:key="id">
          <view class="item-index">{{index + 1}}</view>
          <view class="item-info">
            <view class="item-name">{{item.exerciseName}}</view>
            <view class="item-meta">{{item.reps}}</view>
          </view>
          <button class="item-delete" data-index="{{index}}" catchtap="removeStretch">×</button>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 - 无训练日 -->
  <view wx:else>
    <view class="workout-header">
      <view class="header-left">
        <button class="back-btn" bindtap="goBack">‹</button>
        <view class="header-info">
          <view class="header-title">训练详情</view>
        </view>
      </view>
    </view>
    <view class="empty-state">
      <view class="empty-icon">
        <view class="icon-bar"></view>
        <view class="icon-bar"></view>
        <view class="icon-bar"></view>
      </view>
      <view class="empty-title">没有找到训练日</view>
      <view class="empty-desc">请先回到训练计划页生成或选择一个训练日</view>
      <button class="back-to-plan" bindtap="goBack">返回训练计划</button>
    </view>
  </view>
</view>