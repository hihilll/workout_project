/* 页面基础 */
.plan-page {
  background: #fafafa;
}

.plan-page.builder-mode {
  background: #ffffff;
  padding-top: 20rpx;
}

/* ========== 概览模式 ========== */

/* 头部 */
.plan-header {
  margin-bottom: 24rpx;
}

.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.header-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #111111;
  line-height: 1.1;
}

.header-sub {
  font-size: 24rpx;
  color: #888888;
  margin-top: 8rpx;
}

.header-action {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 1rpx solid #eeeeee;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.action-icon {
  font-size: 32rpx;
}

/* 今日训练卡片 */
.today-card {
  position: relative;
  background: #111111;
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  min-height: 200rpx;
}

.today-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.today-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
}

.today-circle.c1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.today-circle.c2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -80rpx;
  left: -40rpx;
}

.today-content {
  position: relative;
  z-index: 1;
}

.today-badge {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.9);
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.today-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.today-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 24rpx;
}

.meta-dot {
  opacity: 0.5;
}

.today-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.today-arrow {
  font-size: 36rpx;
  opacity: 0.8;
}

/* 周进度 */
.week-progress {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f0f0f0;
}

.week-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.week-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111111;
}

.week-count {
  font-size: 28rpx;
  font-weight: 800;
  color: #111111;
}

.week-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 999rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.week-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--volt-deep), var(--volt));
  border-radius: 999rpx;
  transition: width 0.4s ease;
}

.week-days {
  display: flex;
  justify-content: space-between;
}

.day-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.day-label {
  font-size: 22rpx;
  color: #888888;
  font-weight: 500;
}

.day-item.today .day-label {
  color: #111111;
  font-weight: 700;
}

.day-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  color: #888888;
  transition: all 0.2s ease;
}

.day-dot.active {
  background: #111111;
  color: #ffffff;
}

.day-item.today .day-dot {
  box-shadow: 0 0 0 4rpx rgba(17,17,17,0.2);
}

.day-item.rest .day-dot {
  background: #f0f0f0;
  color: #bbbbbb;
}

.day-item.past .day-dot {
  opacity: 0.5;
}

/* 训练统计 */
.stats-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid #f0f0f0;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #111111;
  margin-bottom: 4rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #888888;
}

/* 快捷入口 */
.shortcuts {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.shortcut-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 12rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: 1rpx solid #f0f0f0;
}

.shortcut-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: var(--volt-soft);
  color: #3d4d0a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.shortcut-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #333333;
}

/* 通用区块头 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111111;
}

.section-sub {
  font-size: 24rpx;
  color: #888888;
}

.section-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.section-action text {
  font-size: 24rpx;
  color: #888888;
}

.action-arrow {
  font-size: 28rpx;
  color: #cccccc;
}

/* 肌群训练量 */
.volume-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f0f0f0;
}

.volume-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.volume-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.volume-name {
  font-size: 24rpx;
  color: #666666;
  width: 80rpx;
  flex-shrink: 0;
}

.volume-bar-wrap {
  flex: 1;
  min-width: 0;
}

.volume-bar {
  height: 20rpx;
  background: #f5f5f5;
  border-radius: 999rpx;
  overflow: hidden;
}

.volume-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--volt-deep), var(--volt));
  border-radius: 999rpx;
  transition: width 0.4s ease;
}

.volume-sets {
  font-size: 24rpx;
  font-weight: 600;
  color: #111111;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

/* 本周计划详情 */
.plan-detail-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f0f0f0;
}

.plan-day-list {
  display: flex;
  flex-direction: column;
}

.plan-day-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.plan-day-item:last-child {
  border-bottom: none;
}

.plan-day-item.rest {
  opacity: 0.6;
}

.plan-day-item.today {
  opacity: 1;
}

.plan-day-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.plan-day-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #111111;
  width: 60rpx;
  flex-shrink: 0;
}

.plan-day-item.today .plan-day-name {
  color: #111111;
}

.plan-day-title {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-day-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.plan-day-meta {
  font-size: 22rpx;
  color: #888888;
}

.plan-day-arrow {
  font-size: 28rpx;
  color: #cccccc;
}

/* 最近训练记录 */
.recent-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f0f0f0;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.recent-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.recent-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: var(--volt-soft);
  color: #3d4d0a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.recent-info {
  flex: 1;
  min-width: 0;
}

.recent-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #111111;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-date {
  display: block;
  font-size: 22rpx;
  color: #888888;
  margin-top: 4rpx;
}

.recent-right {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.recent-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.recent-badge.good {
  background: #f0fdf4;
  color: #16a34a;
}

.recent-badge.normal {
  background: #fff7ed;
  color: #ea580c;
}

.recent-badge.low {
  background: #fef2f2;
  color: #dc2626;
}

/* 警告列表 */
.warning-list {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 14rpx 16rpx;
  background: #fff8e1;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #795548;
  line-height: 1.4;
}

.warning-icon {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ff9800;
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #f0f0f0;
}

.empty-visual {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 28rpx;
}

.empty-circle {
  width: 80rpx;
  height: 80rpx;
  border: 3rpx solid #e0e0e0;
  border-radius: 50%;
  position: absolute;
  top: 10rpx;
  left: 10rpx;
}

.empty-line {
  width: 50rpx;
  height: 3rpx;
  background: #d0d0d0;
  position: absolute;
  top: 45rpx;
  left: 25rpx;
  transform: rotate(-30deg);
}

.empty-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #111111;
  position: absolute;
  top: 20rpx;
  right: 15rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 32rpx;
}

.empty-btn {
  height: 88rpx;
  padding: 0 48rpx;
  background: #111111;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* ========== 分步引导模式 ========== */

/* 引导头部 */
.builder-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.builder-progress {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-steps {
  display: flex;
  align-items: center;
}

.progress-step {
  display: flex;
  align-items: center;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e0e0e0;
  transition: all 0.3s ease;
}

.progress-step.done .step-dot {
  background: var(--volt-deep);
}

.progress-step.current .step-dot {
  background: #111111;
  box-shadow: 0 0 0 6rpx rgba(198, 244, 50, 0.45);
}

.step-line {
  width: 32rpx;
  height: 3rpx;
  background: #e0e0e0;
  margin: 0 4rpx;
}

.progress-step.done .step-line {
  background: var(--volt-deep);
}

.progress-text {
  font-size: 24rpx;
  color: #888888;
  font-weight: 600;
}

/* 步骤标题 */
.step-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #111111;
  line-height: 1.2;
  margin-bottom: 28rpx;
}

/* 步骤内容 */
.step-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 表单卡片 */
.form-card {
  background: #f8f8fa;
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  height: 88rpx;
}

.form-label {
  width: 120rpx;
  font-size: 26rpx;
  color: #111111;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #111111;
  font-weight: 600;
}

.form-unit {
  font-size: 24rpx;
  color: #888888;
  margin-left: 8rpx;
}

.form-divider {
  height: 1rpx;
  background: #e8e8e8;
  margin-left: 120rpx;
}

.form-options {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.option-tag {
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  font-size: 24rpx;
  color: #666666;
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}

.option-tag.active {
  background: #111111;
  border-color: #111111;
  color: #ffffff;
}

/* 伤病选择 */
.injury-section {
  margin-top: 8rpx;
}

.section-label {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 12rpx;
}

.injury-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.injury-tag {
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f8f8fa;
  font-size: 24rpx;
  color: #666666;
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}

.injury-tag.active {
  background: #fff3e0;
  color: #e65100;
  border: 1rpx solid #ffcc80;
}

/* 风险提示 */
.risk-card {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fff8e1;
  border-radius: 14rpx;
}

.risk-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ffa000;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.risk-list {
  font-size: 24rpx;
  color: #795548;
  line-height: 1.6;
}

/* 目标选择 */
.goal-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.goal-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #f8f8fa;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.goal-card.active {
  border-color: #111111;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.goal-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #e8e8e8;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.goal-card.active .goal-icon {
  background: #111111;
  color: #ffffff;
}

.goal-info {
  flex: 1;
  min-width: 0;
}

.goal-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #111111;
}

.goal-desc {
  font-size: 22rpx;
  color: #888888;
  margin-top: 4rpx;
}

.goal-check {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #d0d0d0;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.goal-check.active {
  border: 8rpx solid #111111;
}

/* 条件选择 */
.condition-card {
  background: #f8f8fa;
  border-radius: 18rpx;
  padding: 20rpx;
}

.condition-title {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 12rpx;
}

.condition-options {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.condition-tag {
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  font-size: 26rpx;
  color: #666666;
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}

.condition-tag.active {
  border-color: #111111;
  color: #111111;
  background: #ffffff;
  font-weight: 600;
}

.avoid-input {
  height: 64rpx;
  margin-top: 12rpx;
  padding: 0 16rpx;
  background: #ffffff;
  border-radius: 12rpx;
  font-size: 24rpx;
}

/* 偏好选择 */
.preference-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.preference-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #f8f8fa;
  border-radius: 18rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.preference-card.active {
  border-color: #111111;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.pref-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: #e8e8e8;
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.preference-card.active .pref-icon {
  background: #111111;
  color: #ffffff;
}

.pref-info {
  flex: 1;
  min-width: 0;
}

.pref-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #111111;
}

.pref-desc {
  font-size: 22rpx;
  color: #888888;
  margin-top: 4rpx;
}

.pref-check {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #d0d0d0;
  font-size: 16rpx;
  color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.pref-check.active {
  background: #111111;
  border-color: #111111;
  color: #ffffff;
}

/* 推荐方案 */
.recommend-card {
  background: #f8f8fa;
  border-radius: 20rpx;
  padding: 24rpx;
}

.recommend-badge {
  display: inline-flex;
  align-items: center;
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.recommend-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #111111;
  margin-bottom: 12rpx;
}

.recommend-meta {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: #888888;
}

.recommend-preview {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e8e8e8;
}

.preview-item {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.preview-day {
  font-size: 24rpx;
  font-weight: 700;
  color: #111111;
  min-width: 60rpx;
}

.preview-title {
  font-size: 24rpx;
  color: #666666;
}

/* 营养卡片 */
.nutrition-card {
  background: #f8f8fa;
  border-radius: 20rpx;
  padding: 24rpx;
}

.nutrition-title {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 16rpx;
}

.nutrition-calories {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.cal-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #111111;
}

.cal-unit {
  font-size: 24rpx;
  color: #888888;
}

.nutrition-macros {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e8e8e8;
}

.macro-item {
  text-align: center;
}

.macro-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #111111;
  display: block;
}

.macro-label {
  font-size: 22rpx;
  color: #888888;
  margin-top: 4rpx;
  display: block;
}

/* 其他方案 */
.other-plans {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.other-plan-item {
  padding: 20rpx;
  background: #f8f8fa;
  border-radius: 16rpx;
}

.other-plan-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #111111;
}

.other-plan-desc {
  font-size: 22rpx;
  color: #888888;
  margin-top: 6rpx;
  line-height: 1.5;
}

/* 底部按钮 */
.step-actions {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.primary-btn {
  height: 96rpx;
  background: #111111;
  color: #ffffff;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ghost-btn {
  height: 80rpx;
  background: transparent;
  color: #888888;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.text-btn {
  height: 72rpx;
  background: transparent;
  color: #111111;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 人体肌肉图模块 ========== */
.muscle-map-section {
  margin-bottom: 24rpx;
  padding: 0 24rpx;
}

.muscle-map-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.muscle-map-content {
  display: flex;
  gap: 32rpx;
}

.body-map-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.body-map {
  width: 100%;
  max-width: 200rpx;
  height: 400rpx;
  background: linear-gradient(180deg, #f8f8f8 0%, #f0f0f0 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #e8e8e8;
  position: relative;
}

.body-outline {
  width: 100%;
  height: 100%;
  position: relative;
}

.body-part {
  position: absolute;
  background: #e8e8e8;
  border: 1rpx solid #d0d0d0;
  transition: all 0.3s ease;
}

.body-part.active {
  background: #111111;
  border-color: #333333;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* 头部 */
.head {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
}

/* 颈部 */
.neck {
  width: 24rpx;
  height: 20rpx;
  border-radius: 8rpx;
  left: 50%;
  top: 60rpx;
  transform: translateX(-50%);
}

/* 肩部 */
.shoulder {
  width: 50rpx;
  height: 24rpx;
  border-radius: 12rpx;
  top: 80rpx;
}

.shoulder.left {
  left: 0;
}

.shoulder.right {
  right: 0;
}

/* 胸部 */
.chest {
  width: 45rpx;
  height: 35rpx;
  border-radius: 16rpx;
  top: 100rpx;
}

.chest.left {
  left: 15rpx;
}

.chest.right {
  right: 15rpx;
}

/* 手臂 */
.arm {
  width: 24rpx;
  height: 60rpx;
  border-radius: 12rpx;
  top: 100rpx;
}

.arm.left {
  left: 0;
}

.arm.right {
  right: 0;
}

/* 核心 */
.core {
  width: 70rpx;
  height: 50rpx;
  border-radius: 12rpx;
  left: 50%;
  top: 140rpx;
  transform: translateX(-50%);
}

/* 臀部 */
.hip {
  width: 40rpx;
  height: 30rpx;
  border-radius: 16rpx;
  top: 200rpx;
}

.hip.left {
  left: 15rpx;
}

.hip.right {
  right: 15rpx;
}

/* 腿部 */
.leg {
  width: 36rpx;
  height: 80rpx;
  border-radius: 16rpx;
  top: 230rpx;
}

.leg.left {
  left: 15rpx;
}

.leg.right {
  right: 15rpx;
}

/* 小腿 */
.calf {
  width: 28rpx;
  height: 70rpx;
  border-radius: 14rpx;
  top: 310rpx;
}

.calf.left {
  left: 20rpx;
}

.calf.right {
  right: 20rpx;
}

.map-legend {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  background: #e8e8e8;
  border: 1rpx solid #d0d0d0;
}

.legend-color.active {
  background: #111111;
  border-color: #333333;
}

.legend-text {
  font-size: 20rpx;
  color: #888888;
}

.muscle-stats {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.stats-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.muscle-stat-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.muscle-stat-item:last-child {
  border-bottom: none;
}

.muscle-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e8e8e8;
  border: 2rpx solid #d0d0d0;
  transition: all 0.3s ease;
}

.muscle-dot.active {
  background: #111111;
  border-color: #333333;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.muscle-name {
  flex: 1;
  font-size: 24rpx;
  color: #666666;
}

.muscle-sets {
  font-size: 24rpx;
  font-weight: 600;
  color: #111111;
}
