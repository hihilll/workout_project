/* 头部区域 */
.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.header-date {
  margin-top: 8rpx;
  color: #888888;
  font-size: 24rpx;
}

.avatar-btn {
  width: 72rpx;
  height: 72rpx;
  min-height: 72rpx;
  padding: 0;
  border-radius: 50%;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
}

.mini-avatar {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #555555;
}

/* 空状态 */
.hero-empty {
  min-height: 480rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-illustration {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.illust-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #e0e0e0;
  position: absolute;
  top: 20rpx;
  left: 20rpx;
}

.illust-line {
  position: absolute;
  background: #d0d0d0;
  border-radius: 4rpx;
}

.illust-line.l1 {
  width: 80rpx;
  height: 8rpx;
  top: 80rpx;
  left: 60rpx;
  transform: rotate(-30deg);
}

.illust-line.l2 {
  width: 60rpx;
  height: 8rpx;
  top: 110rpx;
  left: 80rpx;
  transform: rotate(20deg);
}

.illust-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--volt);
  border: 3rpx solid #b3da2d;
  position: absolute;
  top: 60rpx;
  right: 30rpx;
}

.empty-desc {
  margin: 16rpx 0 40rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #888888;
}

/* 今日概览双卡 */
.today-overview {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.overview-card {
  position: relative;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #eeeeee;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  min-height: 240rpx;
  display: flex;
  flex-direction: column;
}

.overview-card.workout-card {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  border-color: transparent;
}

.overview-card.workout-card.rest {
  background: linear-gradient(135deg, #f8f8f8 0%, #ffffff 100%);
  border-color: #e8e8e8;
}

.overview-card.diet-card {
  background: linear-gradient(135deg, #fafafa 0%, #ffffff 100%);
}

.card-badge {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.9);
  align-self: flex-start;
}

.workout-card.rest .card-badge,
.diet-card .card-badge {
  background: #f0f0f0;
  color: #666666;
}

.card-icon-wrap {
  margin: 16rpx 0;
}

.card-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.workout-icon {
  flex-direction: row;
  gap: 6rpx;
}

.workout-icon .icon-bar {
  width: 8rpx;
  height: 36rpx;
  border-radius: 4rpx;
  background: var(--volt);
}

.workout-icon .icon-bar:nth-child(2) {
  height: 44rpx;
  opacity: 0.75;
}

.workout-icon .icon-bar:nth-child(3) {
  height: 28rpx;
  opacity: 0.5;
}

.workout-card.rest .workout-icon .icon-bar {
  background: #cccccc;
  height: 28rpx;
}

.diet-icon {
  position: relative;
}

.icon-plate {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #666666;
}

.icon-food {
  position: absolute;
  top: 8rpx;
  left: 16rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #999999;
}

.card-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #ffffff;
  margin: 8rpx 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.workout-card.rest .card-title,
.diet-card .card-title {
  color: #111111;
}

.diet-card .card-title {
  font-size: 40rpx;
  letter-spacing: -1rpx;
  font-variant-numeric: tabular-nums;
}

.card-meta {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: auto;
}

.workout-card.rest .card-meta,
.diet-card .card-meta {
  color: #888888;
}

.card-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
  font-size: 24rpx;
  font-weight: 700;
  color: var(--volt);
}

.workout-card.rest .card-action,
.diet-card .card-action {
  border-top-color: #eeeeee;
  color: #111111;
}

.action-arrow {
  font-size: 28rpx;
}

/* 营养进度环 */
.nutrition-progress {
  padding: 28rpx;
}

.progress-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.progress-percent {
  font-size: 28rpx;
  font-weight: 700;
  color: #111111;
}

.progress-percent.low {
  color: #f59e0b;
}

.progress-percent.high {
  color: #ef4444;
}

.macro-progress-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.macro-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.macro-ring {
  position: relative;
  width: 100rpx;
  height: 100rpx;
}

/* 真实进度环：conic-gradient 按 --percent 绘制，中心白圆遮出环形 */
.ring-fill {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: conic-gradient(var(--volt-deep) 0, var(--volt) calc(var(--percent) * 1%), #eef1e6 calc(var(--percent) * 1%), #eef1e6 100%);
}

.ring-center {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #111111;
  font-variant-numeric: tabular-nums;
}

.macro-label {
  font-size: 22rpx;
  color: #888888;
}

.macro-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #111111;
}

/* 连续打卡横幅 */
.streak-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #333333 100%);
  border-color: transparent;
  flex-wrap: wrap;
}

.streak-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.streak-number {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--volt);
  line-height: 1;
  letter-spacing: -2rpx;
  font-variant-numeric: tabular-nums;
}

.streak-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  max-width: 96rpx;
  line-height: 1.4;
}

.streak-week {
  display: flex;
  gap: 8rpx;
}

.week-dot {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.week-dot text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.dot-inner {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: transparent;
}

.week-dot.done .dot-inner {
  background: var(--volt);
  border-color: var(--volt);
  color: #111111;
  font-weight: 700;
}

.week-dot.today .dot-inner {
  border-color: var(--volt);
  box-shadow: 0 0 0 4rpx rgba(198, 244, 50, 0.25);
}

/* 体重趋势 */
.weight-trend {
  padding: 28rpx;
}

.trend-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.trend-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #888888;
}

.trend-change {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.trend-change.down {
  background: #f0fdf4;
  color: #16a34a;
}

.trend-change.up {
  background: #fef2f2;
  color: #dc2626;
}

.trend-change.flat {
  background: #f5f5f5;
  color: #666666;
}

.trend-chart {
  display: flex;
  gap: 12rpx;
  height: 180rpx;
}

.chart-y-axis {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-end;
  width: 70rpx;
  font-size: 18rpx;
  color: #aaaaaa;
  padding: 8rpx 0;
}

.chart-bars {
  flex: 1;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 8rpx;
  border-bottom: 1rpx solid #eeeeee;
  padding-bottom: 8rpx;
}

.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  height: 100%;
  justify-content: flex-end;
}

.bar-value {
  font-size: 20rpx;
  font-weight: 700;
  color: #111111;
}

.bar-track {
  width: 100%;
  height: 120rpx;
  display: flex;
  align-items: flex-end;
}

.bar-fill {
  width: 100%;
  border-radius: 6rpx 6rpx 0 0;
  background: linear-gradient(to top, var(--volt-deep), var(--volt));
  transition: height 0.3s ease;
}

.bar-label {
  font-size: 20rpx;
  color: #aaaaaa;
}

.trend-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.trend-start {
  font-size: 24rpx;
  color: #888888;
}

.trend-arrow {
  color: #cccccc;
}

.trend-current {
  font-size: 28rpx;
  font-weight: 700;
  color: #111111;
}

.trend-target {
  margin-left: auto;
  font-size: 22rpx;
  color: #888888;
  padding: 6rpx 14rpx;
  background: #f5f5f5;
  border-radius: 999rpx;
}

/* 快捷操作 */
.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid var(--line);
  box-shadow: 0 4rpx 12rpx rgba(17, 17, 17, 0.04);
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
}

.action-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: var(--volt-soft);
  color: #3d4d0a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  flex-shrink: 0;
}
