/* 页面基础 */
.week-page {
  background: #f5f5f7;
}

/* 头部 */
.week-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.week-header .back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 1rpx solid #eeeeee;
  font-size: 36rpx;
  color: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.week-header .header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111111;
}

.header-placeholder {
  width: 64rpx;
}

/* 概览卡片 */
.overview-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.overview-top {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.overview-info {
  text-align: center;
}

.overview-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #111111;
  line-height: 1;
}

.overview-label {
  font-size: 22rpx;
  color: #888888;
  margin-top: 6rpx;
}

.overview-divider {
  width: 1rpx;
  height: 40rpx;
  background: #e8e8e8;
}

/* 警告列表 */
.warning-list {
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 14rpx 16rpx;
  background: #fff8e1;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #795548;
  line-height: 1.4;
}

.warning-icon {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ff9800;
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

/* 7天安排 */
.days-section {
  margin-bottom: 100rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 16rpx;
}

.day-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.day-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 18rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.day-card.today {
  border-color: #007aff;
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.12);
}

.day-card.rest {
  background: #fafafa;
}

/* 左侧日期 */
.day-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 60rpx;
  flex-shrink: 0;
}

.day-name {
  font-size: 24rpx;
  color: #888888;
  font-weight: 600;
}

.day-card.today .day-name {
  color: #007aff;
}

.day-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #e0e0e0;
}

.day-dot.active {
  background: #007aff;
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.2);
}

/* 中间内容 */
.day-content {
  flex: 1;
  min-width: 0;
}

.day-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.day-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  background: #f0f0f0;
  font-size: 20rpx;
  font-weight: 700;
  color: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.day-icon.rest {
  background: #e8e8e8;
  color: #888888;
}

.day-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111111;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.day-card.rest .day-title {
  color: #888888;
}

.day-meta {
  font-size: 22rpx;
  color: #888888;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-dot {
  opacity: 0.5;
}

.rest-meta {
  color: #aaaaaa;
}

/* 右侧操作 */
.day-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.day-action-btn {
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #007aff;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.day-arrow {
  font-size: 28rpx;
  color: #cccccc;
}

.day-card.today .day-arrow {
  color: #007aff;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 12rpx;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.add {
  background: #f0f0f0;
  color: #333333;
  gap: 6rpx;
}

.action-btn.add text:first-child {
  font-size: 24rpx;
  font-weight: 700;
}

.action-btn.save {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  display: flex;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.ei-bar {
  width: 12rpx;
  height: 48rpx;
  border-radius: 6rpx;
  background: #e0e0e0;
}

.ei-bar:nth-child(2) {
  height: 64rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 32rpx;
}

.empty-btn {
  height: 76rpx;
  padding: 0 36rpx;
  background: #111111;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}